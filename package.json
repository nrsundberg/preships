  "name": "preships-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo for Preships CLI, docs, and admin app.",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "dev:cli": "npm run dev --workspace preships",
    "dev:web": "npm run dev --workspace @preships/web",
    "dev:console": "npm run dev --workspace @preships/console",
    "format": "oxfmt --write .",
    "format:check": "oxfmt .",
    "format:staged": "oxfmt --write",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "lint:staged": "oxlint --fix",
    "precommit": "lint-staged",
    "prepare": "husky"
  },
