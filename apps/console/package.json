{
  "name": "@preships/console",
  "version": "0.1.0",
  "private": true,
  "description": "Preships admin console at console.preships.io (React Router v7 on Cloudflare Workers + D1).",
  "type": "module",
  "scripts": {
    "dev": "npm exec -- react-router dev",
    "build": "npm exec -- react-router build",
    "typecheck": "npm exec -- react-router typegen && node scripts/react-router-type-shims.mjs && tsc --noEmit && tsc -p workers/tsconfig.json --noEmit",
    "test": "node --import tsx --test app/**/*.test.ts",
    "prisma:generate": "prisma generate",
    "prisma:db:push": "prisma db push",
    "db:push:local": "wrangler d1 migrations apply AUTH_DB --local",
    "db:push:remote": "wrangler d1 migrations apply AUTH_DB --remote",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "@prisma/adapter-d1": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "@react-router/node": "^7.9.3",
    "better-auth": "^1.6.4",
    "isbot": "^5",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router": "^7.9.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260416.1",
    "@react-router/dev": "^7.9.3",
    "@tailwindcss/node": "^4.2.2",
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "prisma": "^7.0.0",
    "tailwindcss": "^4.1.4",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^7.1.10",
    "vite-tsconfig-paths": "^5.1.4",
    "wrangler": "^4.40.0"
  }
}
