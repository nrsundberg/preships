{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "preships-web",
  "compatibility_date": "2026-04-15",
  "compatibility_flags": ["nodejs_compat"],
  "main": "./workers/app.ts",
  "assets": {
    "directory": "./build/client"
  },
  "routes": [
    { "pattern": "preships.io", "custom_domain": true },
    { "pattern": "www.preships.io", "custom_domain": true }
  ],
  "observability": {
    "enabled": true
  }
}
