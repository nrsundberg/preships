{
  "name": "preships",
  "version": "0.1.0",
  "description": "Pre-ship QA agent for web applications. Checks your UI before you ship.",
  "type": "module",
  "bin": {
    "preships": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test src/**/*.test.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "qa",
    "testing",
    "ui",
    "browser",
    "playwright",
    "lighthouse",
    "accessibility",
    "ai",
    "agent",
    "pre-ship"
  ],
  "license": "MIT",
  "homepage": "https://preships.io",
  "repository": {
    "type": "git",
    "url": "https://github.com/preships/preships"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "better-sqlite3": "^12.2.0",
    "chalk": "^5.6.2",
    "chokidar": "^4.0.3",
    "commander": "^14.0.1",
    "conf": "^15.0.2",
    "execa": "^9.6.0",
    "fast-glob": "^3.3.3",
    "glob": "^11.0.3",
    "inquirer": "^12.9.6",
    "ora": "^8.2.0",
    "playwright": "^1.55.1",
    "toml": "^3.0.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/inquirer": "^9.0.9",
    "@types/node": "^24.7.2",
    "tsx": "^4.20.6",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  }
}
